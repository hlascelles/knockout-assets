<% # Prepare the asset hash and populate it  %>
<script type="text/javascript"<% if nonce %> nonce="<%= nonce %>"<% end %>>
    var knockout_assets = {};

    <% asset_files.each { |k,v| %>
    knockout_assets['<%= k %>'] = '<%= v %>';
    <% } %>

    ko.bindingHandlers.img = {
        init: function (element, valueAccessor) {
            var str = ko.utils.unwrapObservable(valueAccessor());
            $(element).attr('src', knockout_assets[str]);
        }
    };
</script>

<% # Preload images so templates show instantly when first rendered %>
<% if preload
     asset_files.each { |k, v| %>
        <link rel="preload" href="<%= v %>" as="image"/>
    <% }
       end
    %>